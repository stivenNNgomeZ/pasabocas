# SnackZone - Variables de entorno
# Copia este archivo como .env y ajusta según tu entorno

# Puerto del servidor
PORT=3000

# JWT Secret (cambiar en producción)
JWT_SECRET=cambiar_en_produccion

# Session Secret
SESSION_SECRET=cambiar_en_produccion

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_mysql
DB_NAME=snackzone

# Google OAuth (opcional - para login con Google)
GOOGLE_CLIENT_ID=TU_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TU_CLIENT_SECRET

# Correo para notificaciones (Gmail App Password)
GMAIL_USER=tu_correo@gmail.com
GMAIL_PASS=tu_app_password

# URL del frontend (usado en callbacks OAuth)
FRONTEND_URL=http://localhost:3000
